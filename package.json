{
  "type": "module",
  "name": "@sanity/ui-workshop-plugin-sanity",
  "version": "1.0.0",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "types": "./dist/index.d.ts",
  "source": "./src/index.ts",
  "module": "./dist/index.js",
  "main": "./dist/index.cjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "node": {
        "import": "./dist/index.cjs.js",
        "require": "./dist/index.cjs"
      },
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "build": "run-s clean pkg:build pkg:check",
    "check:types": "tsc --build",
    "clean": "rimraf dist",
    "commit": "cz",
    "dev": "workshop dev",
    "format": "prettier --write --cache --ignore-unknown .",
    "lint": "eslint . --ext .cjs,.js,.jsx,.mjs,.ts,.tsx --quiet",
    "pkg:build": "pkg build --strict",
    "pkg:check": "pkg --strict",
    "prepare": "husky install",
    "prepublishOnly": "pnpm run build",
    "release": "semantic-release",
    "test": "run-s pkg:check",
    "watch": "pkg watch --strict"
  },
  "dependencies": {},
  "devDependencies": {
    "@commitlint/config-conventional": "^17.8.1",
    "@sanity/pkg-utils": "^2.4.10",
    "@sanity/semantic-release-preset": "^4.1.8",
    "@sanity/icons": "^2.11.8",
    "@sanity/ui": "^1.9.3",
    "@sanity/ui-workshop": "^1.2.11",
    "@types/node": "^18.13.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/styled-components": "^5.1.34",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "commitizen": "^4.3.1",
    "commitlint": "^17.8.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^8.0.3",
    "npm-run-all2": "^5.0.0",
    "prettier": "^2.8.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^18.3.1",
    "rimraf": "^4.4.1",
    "sanity": "^3.68.3",
    "sanity-testing-library": "^1.0.0",
    "semantic-release": "^20.1.3",
    "styled-components": "^5.3.11",
    "typescript": "^4.9.5"
  },
  "peerDependencies": {
    "@sanity/ui": "^1",
    "@sanity/ui-workshop": "^1",
    "react": "^18",
    "sanity": "^3",
    "styled-components": "^5.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/ui-workshop-plugin-sanity.git"
  },
  "bugs": {
    "url": "https://github.com/sanity-io/ui-workshop-plugin-sanity/issues"
  },
  "author": "Sanity.io <hello@sanity.io>",
  "homepage": "https://www.sanity.io/",
  "keywords": [],
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*": [
      "prettier --write --cache --ignore-unknown"
    ]
  },
  "packageManager": "pnpm@7.27.0",
  "prettier": {
    "semi": false,
    "printWidth": 100,
    "bracketSpacing": false,
    "singleQuote": true
  },
  "publishConfig": {
    "access": "public"
  },
  "release": {
    "extends": "@sanity/semantic-release-preset",
    "branches": [
      "+([0-9])?(.{+([0-9]),x}).x",
      "main",
      {
        "name": "beta",
        "prerelease": true
      },
      {
        "name": "alpha",
        "prerelease": true
      }
    ]
  }
}
